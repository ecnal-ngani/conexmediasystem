
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents an authorized user within the CONEX Gateway system, storing their profile information and linking to their roles and preferences.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "email": {
          "type": "string",
          "description": "The user's primary email address, often used as a unique identifier for contact purposes.",
          "format": "email"
        },
        "name": {
          "type": "string",
          "description": "The full name of the user."
        },
        "systemId": {
          "type": "string",
          "description": "The tactical system ID (e.g., CX-AD-01)."
        },
        "securityToken": {
          "type": "string",
          "description": "The unique high-entropy passcode for internal access."
        },
        "role": {
          "type": "string",
          "description": "The primary role assigned to this user.",
          "enum": ["ADMIN", "BRAND_MANAGER", "VIDEOGRAPHER", "EDITOR", "INTERN"]
        },
        "status": {
          "type": "string",
          "description": "Current operational status.",
          "enum": ["Office", "WFH", "Offline"]
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the user account was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp indicating when the profile was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "name",
        "systemId",
        "securityToken",
        "role",
        "createdAt",
        "updatedAt"
      ]
    },
    "Verification": {
      "title": "Verification",
      "type": "object",
      "description": "Biometric verification log for WFH compliance.",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userSystemId": { "type": "string" },
        "photoUrl": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isVerified": { "type": "boolean" },
        "confidence": { "type": "number" }
      }
    },
    "Task": {
      "title": "Task",
      "type": "object",
      "description": "Tactical directive assigned to personnel.",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "priority": { "type": "string", "enum": ["URGENT", "HIGH", "NORMAL"] },
        "dueDate": { "type": "string" },
        "status": { "type": "string" },
        "assignedToId": { "type": "string" },
        "assignedToName": { "type": "string" },
        "assignedById": { "type": "string" },
        "assignedByName": { "type": "string" }
      }
    },
    "Project": {
      "title": "Project",
      "type": "object",
      "description": "Production item in the hub.",
      "properties": {
        "fileCode": { "type": "string" },
        "brand": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": "string" },
        "artist": { "type": "string" },
        "dueDate": { "type": "string" }
      }
    },
    "Brand": {
      "title": "Brand",
      "type": "object",
      "description": "Authorized client brand.",
      "properties": {
        "name": { "type": "string" },
        "prefix": { "type": "string" }
      }
    },
    "Schedule": {
      "title": "Schedule",
      "type": "object",
      "description": "Calendar event or shoot.",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string" },
        "date": { "type": "string" },
        "location": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Primary user profiles."
        }
      },
      {
        "path": "/verifications/{id}",
        "definition": {
          "entityName": "Verification",
          "schema": { "$ref": "#/backend/entities/Verification" },
          "description": "Biometric logs."
        }
      },
      {
        "path": "/tasks/{id}",
        "definition": {
          "entityName": "Task",
          "schema": { "$ref": "#/backend/entities/Task" },
          "description": "Assigned internal tasks."
        }
      },
      {
        "path": "/projects/{id}",
        "definition": {
          "entityName": "Project",
          "schema": { "$ref": "#/backend/entities/Project" },
          "description": "Production hub items."
        }
      },
      {
        "path": "/brands/{id}",
        "definition": {
          "entityName": "Brand",
          "schema": { "$ref": "#/backend/entities/Brand" },
          "description": "Registered clients."
        }
      },
      {
        "path": "/schedules/{id}",
        "definition": {
          "entityName": "Schedule",
          "schema": { "$ref": "#/backend/entities/Schedule" },
          "description": "Calendar events."
        }
      }
    ]
  }
}
