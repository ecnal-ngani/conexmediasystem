{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Authorized staff member.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "systemId": { "type": "string" },
        "securityToken": { "type": "string" },
        "role": { "type": "string", "enum": ["ADMIN", "BRAND_MANAGER", "VIDEOGRAPHER", "EDITOR", "INTERN"] },
        "hourlyRate": { "type": "number" },
        "status": { "type": "string", "enum": ["Office", "WFH", "Offline"] },
        "avatarUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "name", "systemId", "securityToken", "role", "createdAt", "updatedAt"]
    },
    "Verification": {
      "title": "Verification",
      "type": "object",
      "description": "Biometric verification log.",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userSystemId": { "type": "string" },
        "photoUrl": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isVerified": { "type": "boolean" },
        "confidence": { "type": "number" }
      }
    },
    "Task": {
      "title": "Task",
      "type": "object",
      "description": "Tactical directive.",
      "properties": {
        "title": { "type": "string" },
        "dueDate": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": "string", "enum": ["URGENT", "HIGH", "NORMAL"] },
        "assignedToId": { "type": "string" },
        "assignedToName": { "type": "string" },
        "assignedById": { "type": "string" },
        "assignedByName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Project": {
      "title": "Project",
      "type": "object",
      "description": "Production item.",
      "properties": {
        "fileCode": { "type": "string" },
        "brand": { "type": "string" },
        "brandId": { "type": "string" },
        "contentIdea": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": "string" },
        "artist": { "type": "string" },
        "type": { "type": "string" },
        "platform": { "type": "string" },
        "dueDate": { "type": "string" },
        "bm": { "type": "string" },
        "canvasLink": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Brand": {
      "title": "Brand",
      "type": "object",
      "description": "Authorized brand.",
      "properties": {
        "name": { "type": "string" },
        "prefix": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Schedule": {
      "title": "Schedule",
      "type": "object",
      "description": "Calendar event.",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string" },
        "date": { "type": "string" },
        "location": { "type": "string" },
        "priority": { "type": "string" },
        "client": { "type": "string" },
        "brandId": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "User profiles."
    },
    "/verifications/{verificationId}": {
      "schema": { "$ref": "#/backend/entities/Verification" },
      "description": "Biometric logs."
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/backend/entities/Task" },
      "description": "Tasks."
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "#/backend/entities/Project" },
      "description": "Projects."
    },
    "/brands/{brandId}": {
      "schema": { "$ref": "#/backend/entities/Brand" },
      "description": "Brands."
    },
    "/schedules/{scheduleId}": {
      "schema": { "$ref": "#/backend/entities/Schedule" },
      "description": "Schedules."
    }
  }
}
