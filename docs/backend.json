
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents the profile information for an authorized user within the CONEX Gateway application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity."
        },
        "systemId": {
          "type": "string",
          "description": "The unique system identifier (e.g., CX-AD-01)."
        },
        "email": {
          "type": "string",
          "description": "The user's email address, used for identification and communication.",
          "format": "email"
        },
        "name": {
          "type": "string",
          "description": "The full name of the user."
        },
        "role": {
          "type": "string",
          "enum": ["ADMIN", "BRAND_MANAGER", "VIDEOGRAPHER", "EDITOR", "INTERN"],
          "description": "The security role assigned to the user."
        },
        "status": {
          "type": "string",
          "enum": ["Office", "WFH", "Offline"],
          "description": "Current presence status."
        },
        "points": {
          "type": "number"
        },
        "xp": {
          "type": "number"
        },
        "badges": {
          "type": "array",
          "items": { "type": "string" }
        },
        "school": {
          "type": "string",
          "description": "Academic institution for interns."
        },
        "course": {
          "type": "string",
          "description": "Degree or course of study."
        },
        "startDate": {
          "type": "string",
          "description": "Internship start date."
        },
        "expectedCompletionDate": {
          "type": "string",
          "description": "Projected end date for the internship."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "avatarUrl": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "email",
        "name",
        "role",
        "systemId"
      ]
    },
    "VerificationLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "VerificationLog",
      "type": "object",
      "description": "Stores biometric verification attempts for WFH compliance.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userSystemId": { "type": "string" },
        "photoUrl": { "type": "string", "description": "Base64 data URI of the captured photo." },
        "timestamp": { "type": "string", "format": "date-time" },
        "isVerified": { "type": "boolean" }
      },
      "required": ["userId", "photoUrl", "timestamp"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores individual user profiles."
        }
      },
      {
        "path": "/verifications/{logId}",
        "definition": {
          "entityName": "VerificationLog",
          "schema": {
            "$ref": "#/backend/entities/VerificationLog"
          },
          "description": "Stores all biometric check-in attempts."
        }
      }
    ]
  }
}
