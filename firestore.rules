rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CONEX Gateway Security Rules
     * 
     * Core Philosophy:
     * This ruleset implements a robust Role-Based Access Control (RBAC) system powered by 
     * Authorization Independence. Security decisions for high-stakes data (Content) are 
     * decoupled from complex role logic using denormalized access maps.
     * 
     * Data Structure:
     * - /users/{userId}: Primary user profiles, owned by the respective user.
     * - /system_roles_admin/{adminId}: A lookup collection for global administrative privileges.
     * - /content/{contentId}: The primary repository for media and resources.
     * - /user_content_access/{userId}/content/{contentId}: A denormalized "access map" used
     *   to grant read permissions to Content without performing expensive multi-document lookups.
     * - /users/{userId}/preferences & /recommendations: User-specific subcollections.
     * 
     * Key Security Decisions:
     * 1. Authorization Independence: Content read access is determined by the existence of a 
     *    record in the 'user_content_access' subcollection, managed by backend Cloud Functions.
     * 2. Existence-Based Roles: Admin status is verified by checking for a document in the 
     *    'system_roles_admin' collection, making admin checks atomic and high-performance.
     * 3. Ownership-Based Writes: Content authors and profile owners manage their own data, 
     *    while system admins retain global override capabilities.
     * 4. Relational Integrity: On creation of user-scoped documents, the rules enforce that 
     *    internal ID fields match the Firestore path parameters.
     */

    // --- Helper Functions ---

    /** Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the user is the owner of the document based on the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks if the user has global administrative privileges via lookup. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/system_roles_admin/$(request.auth.uid));
    }

    /** Checks if the user is the owner and the document exists (for updates/deletes). */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /** Checks if the user is an admin and the document exists (for updates/deletes). */
    function isExistingAdmin() {
      return isAdmin() && resource != null;
    }

    /** Verifies content access via the denormalized access collection. */
    function hasContentAccess(contentId) {
      return isSignedIn() && exists(/databases/$(database)/documents/user_content_access/$(request.auth.uid)/content/$(contentId));
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the User profile collection. Users can manage their own profiles.
     * @path /users/{userId}
     * @allow Authenticated user matching the {userId} (create, get, list, update, delete).
     * @deny Mismatched UID or unauthenticated access.
     * @principle Enforces strict user-ownership model and relational integrity on ID.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update, delete: if (isExistingOwner(userId) || isExistingAdmin()) && (request.resource.data.id == resource.data.id || request.method == 'delete');
    }

    /**
     * @description Administrative lookup collection. Only admins can view or modify the admin list.
     * @path /system_roles_admin/{adminId}
     * @allow Admins managing the admin list.
     * @deny Non-admin users.
     * @principle Existence-over-content pattern for global roles.
     */
    match /system_roles_admin/{adminId} {
      allow get, list, create, update, delete: if isAdmin();
    }

    /**
     * @description System role definitions. Read access is open to all authenticated users for UI purposes.
     * @path /roles/{roleId}
     * @allow Signed-in users (get, list), Admins (all writes).
     * @deny Unauthenticated reads, non-admin writes.
     * @principle Restricts structural configuration to system administrators.
     */
    match /roles/{roleId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Exclusive media and resources. Read access is gated by the denormalized access map.
     * @path /content/{contentId}
     * @allow Users with a 'user_content_access' record (get), Admins or Authors (write).
     * @deny Unauthorized users or authors attempting to change ownership.
     * @principle Authorization Independence for high-performance gated access.
     */
    match /content/{contentId} {
      allow get: if hasContentAccess(contentId) || isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
      allow list: if isSignedIn(); // Filtering is handled by client querying the access map.
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.authorId == request.auth.uid);
      allow update, delete: if isExistingAdmin() || (isSignedIn() && resource != null && resource.data.authorId == request.auth.uid);
    }

    /**
     * @description Denormalized access map. Managed by Cloud Functions, read by users to see their permissions.
     * @path /user_content_access/{userId}/content/{contentId}
     * @allow User matching {userId} (get, list), Admins (all).
     * @deny Client-side writes by non-admins.
     * @principle Queryable Access Pattern (QAP) for the user dashboard.
     */
    match /user_content_access/{userId}/content/{contentId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create, update, delete: if isAdmin(); // Managed by backend functions.
    }

    /**
     * @description Individual user preferences for content personalization.
     * @path /users/{userId}/preferences/{preferenceId}
     * @allow The owner of the parent user profile (all permissions).
     * @deny Access by other users.
     * @principle Path-based ownership for private subcollections.
     */
    match /users/{userId}/preferences/{preferenceId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update, delete: if (isExistingOwner(userId) || isExistingAdmin()) && (request.resource.data.userId == resource.data.userId || request.method == 'delete');
    }

    /**
     * @description AI-generated content recommendations.
     * @path /users/{userId}/recommendations/{recommendationId}
     * @allow The owner of the profile (get, list), Admins/AI (write).
     * @deny Client-side creation or modification of recommendations.
     * @principle Restricts write access to internal system processes (Admins/Functions).
     */
    match /users/{userId}/recommendations/{recommendationId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create, update, delete: if isAdmin(); // Recommendations are generated by the AI system/Admin.
    }

  }
}