
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CONEX Gateway Security Rules - CX-SEC-DEPLOY-002
     * 
     * Core Philosophy:
     * This ruleset implements Role-Based Access Control (RBAC).
     * For this prototype, collection-level access is granted to all authenticated 
     * personnel to support query-based login and cross-departmental visibility.
     */

    // --- Helper Functions ---

    /** Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the user has global administrative privileges via lookup. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/system_roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the User registry.
     * @principle Permits lookup by email during login and management by personnel.
     */
    match /users/{userId} {
      allow read, create, update, delete: if isSignedIn();
    }

    /**
     * @description Administrative lookup collection.
     */
    match /system_roles_admin/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * @description Operational Collections (Verifications, Tasks, Projects, etc.)
     * @principle Permits access to authenticated personnel within the private network.
     */
    match /verifications/{id} {
      allow read, write: if isSignedIn();
    }

    match /tasks/{id} {
      allow read, write: if isSignedIn();
    }

    match /projects/{id} {
      allow read, write: if isSignedIn();
    }

    match /brands/{id} {
      allow read, write: if isSignedIn();
    }

    match /schedules/{id} {
      allow read, write: if isSignedIn();
    }

    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /content/{contentId} {
      allow read, write: if isSignedIn();
    }

    match /user_content_access/{userId}/content/{contentId} {
      allow read, write: if isSignedIn();
    }

  }
}
