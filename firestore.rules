rules_version = '2';

/**
 * CONEX MEDIA - Secure Network Policy
 * 
 * Deployment ID: CX-SEC-2024-009-FINAL
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Authorization Helpers ---

    function isAuthenticated() {
      return request.auth != null;
    }

    // --- Collection Policies ---

    // Staff Registry: Allow authenticated users to read and update their own profile/status.
    match /users/{userId} {
      allow read, write: if isAuthenticated();
    }

    // Attendance Verification: Crucial for WFH identity compliance.
    match /verifications/{id} {
      allow read, write: if isAuthenticated();
    }

    // Internal Tasks: Staff directives and deadlines.
    match /tasks/{id} {
      allow read, write: if isAuthenticated();
    }

    // Production Hub: Active projects and file tracking.
    match /projects/{id} {
      allow read, write: if isAuthenticated();
    }

    // Client Registry: Authorized brand list.
    match /brands/{id} {
      allow read, write: if isAuthenticated();
    }

    // Operations Calendar: Master shoot and meeting schedules.
    match /schedules/{id} {
      allow read, write: if isAuthenticated();
    }

  }
}