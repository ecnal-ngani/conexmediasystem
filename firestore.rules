rules_version = '2';

/**
 * CONEX MEDIA — Role-Based Security Policy
 * 
 * Uses an `auth_map` bridge collection to resolve the Firebase Anonymous
 * Auth UID → application user ID + role. The auth_map entry is created
 * during login and deleted on logout.
 *
 * Deployment ID: CX-SEC-2026-RBAC-001
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // HELPER FUNCTIONS
    // =========================================================================

    /** True if the request has any Firebase Auth credential (including anonymous). */
    function isSignedIn() {
      return request.auth != null;
    }

    /** True if the caller has a valid auth_map entry (completed the login flow). */
    function isMappedUser() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/auth_map/$(request.auth.uid));
    }

    /** Returns the auth_map document data for the current caller. */
    function getAuthMap() {
      return get(/databases/$(database)/documents/auth_map/$(request.auth.uid)).data;
    }

    /** Returns the application role string (ADMIN, BRAND_MANAGER, etc.). */
    function getUserRole() {
      return getAuthMap().role;
    }

    /** Returns the application-level userId (Firestore document ID in /users). */
    function getUserId() {
      return getAuthMap().userId;
    }

    /** Shorthand: caller is a mapped user with role == ADMIN. */
    function isAdmin() {
      return isMappedUser() && getUserRole() == 'ADMIN';
    }

    /** Shorthand: caller is a mapped user whose role is in the provided list. */
    function hasRole(allowedRoles) {
      return isMappedUser() && getUserRole() in allowedRoles;
    }

    // =========================================================================
    // AUTH SESSION MAPPING  (bridge: Firebase UID → app user)
    // =========================================================================
    match /auth_map/{uid} {
      // Users can only read their own mapping
      allow read: if isSignedIn() && request.auth.uid == uid;

      // Create: must be own UID, must reference an existing user doc,
      // and the role must match what's actually stored in the user doc.
      allow create: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.keys().hasAll(['userId', 'role', 'email'])
        && request.resource.data.userId is string
        && request.resource.data.role is string
        && exists(/databases/$(database)/documents/users/$(request.resource.data.userId))
        && get(/databases/$(database)/documents/users/$(request.resource.data.userId)).data.role
           == request.resource.data.role;

      // Update: own UID only, cannot change the userId binding
      allow update: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.userId == resource.data.userId;

      // Delete: own UID only (logout cleanup)
      allow delete: if isSignedIn() && request.auth.uid == uid;
    }

    // =========================================================================
    // USERS
    // =========================================================================
    match /users/{userId} {
      // Read: any signed-in user (required for login email lookup before
      // auth_map exists). NOTE: for production hardening, move the login
      // lookup to a Cloud Function to avoid exposing security tokens.
      allow read: if isSignedIn();

      // Create: any signed-in user (supports master bootstrap flow where
      // the very first admin account is auto-created on first login).
      allow create: if isSignedIn();

      // Update: admin can update anyone; mapped users can update their own
      // document only (profile edits, heartbeat, status sync).
      allow update: if isMappedUser() && (isAdmin() || getUserId() == userId);

      // Delete: admin only
      allow delete: if isAdmin();
    }

    // =========================================================================
    // VERIFICATIONS (Attendance Audit Log)
    // =========================================================================
    match /verifications/{id} {
      // Read: any mapped user (dashboard, attendance history)
      allow read: if isMappedUser();

      // Create: any mapped user (clock-in / clock-out records)
      allow create: if isMappedUser();

      // Update/Delete: admin only (audit log should be immutable)
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // =========================================================================
    // PROJECTS
    // =========================================================================
    match /projects/{id} {
      allow read: if isMappedUser();
      allow create: if hasRole(['ADMIN', 'BRAND_MANAGER', 'EDITOR', 'VIDEOGRAPHER']);
      allow update: if hasRole(['ADMIN', 'BRAND_MANAGER', 'EDITOR', 'VIDEOGRAPHER']);
      allow delete: if hasRole(['ADMIN', 'BRAND_MANAGER']);
    }

    // =========================================================================
    // TASKS
    // =========================================================================
    match /tasks/{id} {
      allow read: if isMappedUser();
      allow create: if hasRole(['ADMIN', 'BRAND_MANAGER']);
      // Any mapped user can update (e.g. mark as completed)
      allow update: if isMappedUser();
      allow delete: if hasRole(['ADMIN', 'BRAND_MANAGER']);
    }

    // =========================================================================
    // BRANDS
    // =========================================================================
    match /brands/{id} {
      allow read: if isMappedUser();
      allow write: if isAdmin();
    }

    // =========================================================================
    // SCHEDULES
    // =========================================================================
    match /schedules/{id} {
      allow read: if isMappedUser();
      allow create: if hasRole(['ADMIN', 'BRAND_MANAGER']);
      allow update: if hasRole(['ADMIN', 'BRAND_MANAGER']);
      allow delete: if hasRole(['ADMIN', 'BRAND_MANAGER']);
    }

    // =========================================================================
    // GLOBAL SETTINGS
    // =========================================================================
    match /global_settings/{id} {
      allow read: if isMappedUser();
      allow write: if isAdmin();
    }

    // =========================================================================
    // PAYROLL TRANSACTIONS (Admin-only — sensitive financial data)
    // =========================================================================
    match /payroll_transactions/{id} {
      allow read, write: if isAdmin();
    }

    // =========================================================================
    // LEAVE REQUESTS
    // =========================================================================
    match /leave_requests/{id} {
      allow read: if isMappedUser();
      // Any mapped user can submit a leave request
      allow create: if isMappedUser();
      // Only admin can approve / decline / delete
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

  }
}
