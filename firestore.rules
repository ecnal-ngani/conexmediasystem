rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CONEX Gateway Security Rules
     * Updated: Authorized read/write for tasks and users with identity check.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Allow users to look up their email during mock login and sync profiles
    match /users/{userId} {
      allow read: if true; 
      allow write: if isSignedIn(); 
    }

    match /schedules/{scheduleId} {
      allow read, write: if isSignedIn();
    }

    match /tasks/{taskId} {
      allow read, write: if isSignedIn();
    }

    match /projects/{projectId} {
      allow read, write: if isSignedIn();
    }

    match /verifications/{logId} {
      allow read, write: if isSignedIn();
    }

    match /brands/{brandId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /roles/{roleId} {
      allow read: if true;
      allow write: if false;
    }
  }
}