
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CONEX Gateway Security Rules - CX-SEC-2024-009-FINAL
     * 
     * Core Philosophy:
     * This ruleset implements strict Role-Based Access Control (RBAC).
     * Permissions are explicitly granted to authenticated personnel to 
     * resolve collection-wide listing errors.
     */

    // --- Helper Functions ---

    /** Checks if the request is from a signed-in node (anonymous or email). */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the user has global administrative privileges via lookup. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/system_roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the User registry.
     * Permits authorized lookup during network synchronization.
     */
    match /users/{userId} {
      allow read, write: if isSignedIn();
    }

    /**
     * @description Operational Collections (Verifications, Tasks, Projects, etc.)
     * Uses recursive matching to ensure 'list' and 'get' are correctly authorized.
     */
    match /verifications/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    match /tasks/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    match /projects/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    match /brands/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    match /schedules/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    /**
     * @description Administrative Nodes.
     */
    match /system_roles_admin/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /content/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    match /user_content_access/{userId}/content/{contentId} {
      allow read, write: if isSignedIn();
    }

  }
}
