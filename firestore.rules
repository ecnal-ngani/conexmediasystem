
rules_version = '2';

/**
 * CONEX MEDIA - Secure Network Policy
 * 
 * Deployment ID: CX-SEC-2024-009-FINAL
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Authorization Helpers ---

    function isAuthenticated() {
      return request.auth != null;
    }

    // --- Global Collection Policy ---
    // All authenticated staff members can read and write to operational collections.
    
    match /users/{userId} {
      allow read, write: if isAuthenticated();
    }

    match /verifications/{id} {
      allow read, write: if isAuthenticated();
    }

    match /tasks/{id} {
      allow read, write: if isAuthenticated();
    }

    match /projects/{id} {
      allow read, write: if isAuthenticated();
    }

    match /brands/{id} {
      allow read, write: if isAuthenticated();
    }

    match /schedules/{id} {
      allow read, write: if isAuthenticated();
    }

  }
}
