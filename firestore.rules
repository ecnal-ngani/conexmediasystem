rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CONEX MEDIA Security Rules
     * Updated: Enforcing explicit permission nodes for all operational data.
     * Deployment ID: CX-SEC-2024-005-STABLE
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Profiles: Shared read, restricted write.
    match /users/{userId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Biometrics & Attendance: Explicitly allowing list and get for authorized personnel.
    match /verifications/{logId} {
      allow get, list, create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    // Command Nodes: Authenticated access required for all records.
    match /tasks/{taskId} {
      allow read, write: if isSignedIn();
    }

    match /projects/{projectId} {
      allow read, write: if isSignedIn();
    }

    match /schedules/{scheduleId} {
      allow read, write: if isSignedIn();
    }

    // External Brands: Read access for sync, restricted updates.
    match /brands/{brandId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Default: Deny all other access.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
