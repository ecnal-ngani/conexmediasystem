rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CONEX MEDIA Security Rules
     * Updated: Enforcing authenticated access for all production nodes.
     * Explicitly permitting 'list' operations for authenticated personnel.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Profiles: Public read for identity synchronization, restricted write.
    match /users/{userId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Operations: Standard authenticated access for command nodes.
    match /schedules/{scheduleId} {
      allow read, write: if isSignedIn();
    }

    match /tasks/{taskId} {
      allow read, write: if isSignedIn();
    }

    match /projects/{projectId} {
      allow read, write: if isSignedIn();
    }

    // Biometrics: Verified access for attendance tracking.
    // Explicitly defining get/list/write to ensure listing is permitted for authenticated personnel.
    match /verifications/{logId} {
      allow get, list, write: if isSignedIn();
    }

    match /brands/{brandId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /roles/{roleId} {
      allow read: if true;
      allow write: if false;
    }
  }
}