rules_version = '2';

/**
 * CONEX MEDIA - Standard Security Policy
 * 
 * This ruleset ensures that only authorized staff can access internal data.
 * Deployment ID: CX-SEC-2024-009-FINAL
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Authorization Helpers ---

    // Returns true if the user has logged in via the app's secure gate.
    function isAuthenticated() {
      return request.auth != null;
    }

    // --- Collection Policies ---

    // Staff Profiles: Authenticated staff can read/write their own profiles.
    match /users/{userId} {
      allow read, write: if isAuthenticated();
    }

    // Operational Data: Attendance logs, Tasks, Projects, and Calendars.
    // These require a valid login to ensure internal data privacy.
    match /verifications/{allPaths=**} {
      allow read, write: if isAuthenticated();
    }

    match /tasks/{allPaths=**} {
      allow read, write: if isAuthenticated();
    }

    match /projects/{allPaths=**} {
      allow read, write: if isAuthenticated();
    }

    match /brands/{allPaths=**} {
      allow read, write: if isAuthenticated();
    }

    match /schedules/{allPaths=**} {
      allow read, write: if isAuthenticated();
    }

    // System Roles: Only verified administrators should touch these configurations.
    match /system_roles_admin/{adminId} {
      allow read: if isAuthenticated();
    }

  }
}
