
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CONEX Gateway Security Rules
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Allow users to look up their email during mock login
    match /users/{userId} {
      allow read: if true; 
      allow write: if true; // In a production app, restrict this to owners
    }

    match /schedules/{scheduleId} {
      allow read, write: if true;
    }

    match /tasks/{taskId} {
      allow read, write: if true;
    }

    match /projects/{projectId} {
      allow read, write: if true;
    }

    match /verifications/{logId} {
      allow read, write: if true;
    }

    match /roles/{roleId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
